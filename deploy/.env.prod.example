# Generated by deploy/install.sh as deploy/.env (chmod 0600).
# This example documents the keys; do not commit a real .env.

# --- Database ---
POSTGRES_USER=openpdf_app
POSTGRES_DB=openpdf
POSTGRES_PASSWORD=          # generated (>=32 chars)

# --- Object storage (MinIO) ---
MINIO_ROOT_USER=            # generated
MINIO_ROOT_PASSWORD=        # generated (>=32 chars)

# --- Auth ---
JWT_SECRET=                 # generated (>=32 chars)

# --- Runtime ---
NODE_ENV=production

# --- Deployment metadata ---
# Self-managed HTTPS: set a domain (Caddy gets a Let's Encrypt cert, serves 80+443).
# Behind a provider's reverse proxy: leave OPENPDF_DOMAIN empty and serve HTTP on HTTP_PUBLISH.
OPENPDF_DOMAIN=             # empty => HTTP-only; provider proxy handles the domain + SSL
OPENPDF_ACME_EMAIL=        # required only when a domain is set
HTTP_PUBLISH=80            # host port Caddy listens on in HTTP-only/proxied mode

# Baked into the web client bundle at build time (routed by Caddy):
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_PDF_ENGINE_URL=/pdf
